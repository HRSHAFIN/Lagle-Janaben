# MySQL Database Configuration
DB_HOST="127.0.0.1"
DB_NAME="lagle_janaben"
DB_USERNAME="root"
DB_PASSWORD=""

# SSLCOMMERZ Credentials (Defaults to sandbox 'testbox' / 'testbox@ssl')
SSLCOMMERZ_STORE_ID="testbox"
SSLCOMMERZ_STORE_PASSWORD="testbox@ssl"
SSLCOMMERZ_IS_SANDBOX="true"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="http://localhost/Lagle-Janaben"

# Google Sign-In (Google Identity Services)
# Create an OAuth 2.0 Client ID (Web application) at https://console.cloud.google.com/apis/credentials
# and add your dev/prod origins under "Authorized JavaScript origins".
# VITE_GOOGLE_CLIENT_ID is read by the frontend to render the Google button.
# GOOGLE_CLIENT_ID is read by the PHP backend to verify the token audience.
VITE_GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_ID=""
